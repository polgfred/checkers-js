{
  "compilerOptions": {
    "outDir": "./lib/",
    "noImplicitAny": true,
    "jsx": "react-jsx",
    "target": "esnext",
    "allowJs": true,
    "esModuleInterop": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "lib": ["ESNext", "DOM"],
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules/**/*"]
}
